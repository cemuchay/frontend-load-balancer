{
  "name": "frontend-load-balancer",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @app/backend\" \"npm run dev -w @app/frontend\"",
    "build": "npm run build -w @pkg/load-balancer && npm run build -w apps/frontend",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}